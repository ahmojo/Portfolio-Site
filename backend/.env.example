# ── Portfolio backend configuration ──────────────────────────
# Copy this file to ".env" and tweak. Production refuses placeholder secrets.

PORTFOLIO_ENV=development

# CORS: origins allowed to call the API (comma-separated list).
#PORTFOLIO_ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000","null"]

# GitHub repo metadata (used by /api/projects).
PORTFOLIO_GITHUB_USER=ahmojo
# Optional: a personal access token raises the rate limit 60 -> 5000/h.
#PORTFOLIO_GITHUB_TOKEN=<github-token>

# Map project titles (as shown on the site) to "user/repo".
#PORTFOLIO_PROJECTS={"Regal-Erkennung für KMU":"ahmojo/Badenhackt_KMU_Trifft_KI","Codex Claude Transfer":"ahmojo/codex-claude-transfer"}

# "Now" status — a token required to UPDATE /api/now. Leave empty for open local dev.
#PORTFOLIO_NOW_TOKEN=change-me

# Optional public uptime badge. Keep the API key server-side; never put it in
# index.html or admin/admin.html. Without a key, /api/uptime shows local status
# and links to the public UptimeRobot page.
#PORTFOLIO_UPTIME_ROBOT_API_KEY=<uptimerobot-api-key>
#PORTFOLIO_UPTIME_ROBOT_MONITOR_ID=123456789
PORTFOLIO_UPTIME_ROBOT_STATUS_PAGE_URL=https://stats.uptimerobot.com/PFy2MRBznP
#PORTFOLIO_UPTIME_CACHE_SECONDS=300

# ── ADMIN PANEL ──────────────────────────────────────────────
# Password for the /admin control panel. CHANGE THIS before deploying.
# Login at http://localhost:8000/admin
PORTFOLIO_ADMIN_PASSWORD=change-this-before-deploy
# Secret used to sign admin session cookies. If empty, one is auto-generated
# and persisted to data/.session_secret on first run. Set explicitly for prod.
# Generate one with: openssl rand -base64 48
PORTFOLIO_SESSION_SECRET=change-this-to-a-long-random-session-secret
# How long a login session lasts, in hours.
#PORTFOLIO_SESSION_TTL_HOURS=12
# Production behind Cloudflare HTTPS should keep this true.
#PORTFOLIO_SECURE_COOKIES=true
# Keep API docs disabled in production unless you explicitly need them.
#PORTFOLIO_EXPOSE_DOCS=false
